---
import "../styles/global.css";

const { title = "My Blog" } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body
    class="min-h-screen bg-zinc-900"
    style="background-image: url('/images/Xueli_warm_short.jpg'); background-size: cover; background-position: center; background-attachment: fixed;"
  >
    <!-- 整体轻微暗化，让背景图别太抢 -->
    <div class="min-h-screen bg-black/25">
      <!-- 中间这条就是“桌布式”的纵向阅读栏 -->
      <div class="mx-auto min-h-screen max-w-4xl bg-white/65 px-6 py-10 shadow-2xl backdrop-blur-lg md:px-10">
        <header class="mb-10 border-b border-zinc-800/10 pb-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
            <div>
              <a href="/" class="text-3xl font-semibold tracking-wide text-zinc-900">
                纪言的博客
              </a>
              <p class="mt-2 text-sm text-zinc-700">
                关于 LLM、Memory、RAG 与系统设计
              </p>
            </div>

            <nav class="flex gap-6 text-sm text-zinc-700">
              <a href="/" class="transition hover:text-black">首页</a>
              <a href="/blog" class="transition hover:text-black">博客</a>
            </nav>
          </div>
        </header>

        <main class="mx-auto max-w-3xl">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>