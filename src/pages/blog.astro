---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const allPosts = Object.values(import.meta.glob("./posts/*.md", { eager: true }));

const withBase = (url) => `${base}${String(url).replace(/^\/+/, "")}`;
---

<BaseLayout title="博客">
  <section class="space-y-8">
    <div class="text-center">
      <h1 class="mt-3 text-4xl font-bold">文章列表</h1>
    </div>

    <ul class="space-y-4">
      {allPosts.map((post) => (
        <li class="rounded-2xl border border-white/40 bg-white/50 p-5 transition hover:bg-white/65">
          <a href={withBase(post.url)} class="block">
            <div class="text-xl font-semibold text-zinc-900">
              {post.frontmatter.title}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>