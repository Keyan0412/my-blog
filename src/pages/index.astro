---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;

const withBase = (path = "") =>
  `${base.replace(/\/$/, "")}/${path.replace(/^\/+/, "")}`;
---

<BaseLayout title="首页">
  <section class="space-y-6 text-center">
    <p class="text-sm uppercase tracking-[0.35em] text-zinc-500">
      Astro + Tailwind
    </p>

    <h1 class="text-4xl font-bold leading-tight md:text-6xl">
      我的第一个博客
    </h1>

    <p class="mx-auto max-w-2xl text-base leading-8 text-zinc-700 md:text-lg">
      这里会记录我对大模型、Memory、RAG、检索评测与系统设计的思考。
      先把它做成一个真正属于自己的地方。
    </p>

	<img
      src={withBase("images/Xueli_warm.jpg")}
      alt="Cover picture"
      class="mx-auto w-full max-w-2xl rounded-3xl shadow-xl"
    />

    <div class="pt-4">
      <a
        href={withBase("blog/")}
        class="inline-block rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white transition hover:scale-[1.02] hover:bg-black"
      >
        查看文章
      </a>
    </div>
  </section>
</BaseLayout>